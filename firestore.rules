rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared household: one document per household holds a `members` list of
    // Firebase Auth UIDs. Everything under it (budgets, expenses, categories)
    // is readable/writable only by those members.
    match /households/{householdId} {
      // Any signed-in user may read the household doc itself, so a not-yet-added
      // partner can see it exists and knows to ask to be added. The doc holds
      // only opaque UIDs — no personal information.
      allow get: if request.auth != null;

      // A household can only be created by a user listing themselves as the sole
      // initial member (nobody can create one on someone else's behalf).
      allow create: if request.auth != null
        && request.resource.data.members is list
        && request.resource.data.members.hasOnly([request.auth.uid]);

      // Only an existing member can change the household (e.g. add a partner).
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow delete: if false;

      // All finance data lives in subcollections, gated by household membership.
      match /{document=**} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
      }
    }

    // Legacy per-user data (users/{uid}/...). Kept so a user can still read their
    // own pre-sharing data during the one-time migration into a household, and as
    // an untouched backup afterwards.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
